OPENAI_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yc_search

# Clerk auth (required once auth is enabled in prod; dev can run w/o, but sign-in won't work)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# optional:
# SYNC_TOKEN=your-shared-secret-for-api-sync
# SQLITE_IMPORT_PATH=./data/yc_search.sqlite
# SYNC_SCRAPE_LIMIT=25
# SYNC_EMBED_LIMIT=50
# SYNC_GITHUB_LIMIT=50
# SYNC_FOUNDER_SITE_CRAWL_LIMIT=50
# SYNC_EXA_LIMIT=20
# GITHUB_TOKEN=           # optional, bumps GitHub API from 60/hr to 5000/hr
# EXA_API_KEY=            # optional, enables founder mention enrichment via Exa
CRAWL4AI_PYTHON_BIN=.venv/bin/python
CRAWL4AI_PAGE_TIMEOUT_MS=35000
